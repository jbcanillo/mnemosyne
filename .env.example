# ═══════════════════════════════════════════════════════════════
#  Mnemosyne RAG Server — Environment Configuration
#  Copy this to .env and fill in all values before deploying:
#    cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Version ─────────────────────────────────────────────────────────
MNEMOSYNE_VERSION=v1.0.0

# ── Server ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3002

# ── Authentication (REQUIRED) ────────────────────────────────────
# Generate RAG_API_KEY with: openssl rand -hex 32
RAG_API_KEY=randomlygeneratedapikey1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef
ADMIN_USERNAME=username
ADMIN_PASSWORD=password
SESSION_TTL_HOURS=8

# ── OpenRouter — Cloud LLM (REQUIRED) ────────────────────────────
# Sign up free at https://openrouter.ai  → Keys → Create Key
# Free models need no credits. Add credits only for paid models.
OPENROUTER_API_KEY=sk-or-v1-yourkeyhere1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# Set the default model for all queries. Users can switch models in the UI if multiple are added.:
OPENROUTER_MODEL=openrouter_model_name_here

# Application URL (for CORS and email links)
APP_URL=http://localhost:3002

# ── Ollama — Embeddings only (runs in Docker) ─────────────────────
# Only nomic-embed-text is used — no LLM model needed in Ollama
OLLAMA_HOST=http://ollama:11434
EMBED_MODEL=nomic-embed-text

# ── ChromaDB ──────────────────────────────────────────────────────
CHROMA_URL=http://chromadb:8000
CHROMA_COLLECTION=mnemosyne_knowledge

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
CACHE_TTL=3600

# ── RAG Tuning ────────────────────────────────────────────────────
TOP_K=5
MIN_RELEVANCE_SCORE=0.15
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_TOKEN=512

# ── Rate Limiting ─────────────────────────────────────────────────
# Mnemosyne uses smart endpoint-specific rate limiting:
# - Login: 10 attempts per 15 min (brute force protection)
# - Queries: 150 req/min for authenticated, 60 req/min for unauthenticated
# - Status/Health: 300 req/min (high for polling)
# - Uploads: 10 uploads per min
# Authenticated requests (with X-Session-Token or X-API-Key) get higher limits
# Rate limiting and performance tuning
RATE_LIMIT_MAX=120          # Max requests per minute for authenticated users
QUERY_RATE_LIMIT=150        # Max query requests per minute
QUERY_CONCURRENCY=10        # Max concurrent query processing

# ── Upload ────────────────────────────────────────────────────────
MAX_FILE_SIZE=50
UPLOAD_DIR=/tmp/rag-uploads

# ── OCR ──────────────────────────────────────────────────────────
# Enable/disable OCR (true/false)
OCR_ENABLED=true
# Minimum text length to consider extraction successful
OCR_MIN_TEXT_LENGTH=10
# OCR language (tesseract language code, default: eng)
OCR_LANG=eng

# ── RAG UI Configuration ────────────────────────────────────────────
REACT_APP_API_URL=/api
REACT_APP_EXAMPLE_QUERIES='["What vital data are available on this document?","Summarize the key points in the knowledge base","How does the information in the documents relate to each other?","Who are the persons involved?","When were the events described in the documents?"]'

# ── Guardrails Configuration ─────────────────────────────────────────
# Security features for PDPA compliance and jailbreak prevention
# Set to 'false' to disable, default is 'true'
ENABLE_INPUT_VALIDATION=true
ENABLE_PROMPT_HARDENING=true
ENABLE_OUTPUT_FILTERING=true
ENABLE_ENHANCED_LOGGING=true
ENABLE_DOCUMENT_SENSITIVITY=true
