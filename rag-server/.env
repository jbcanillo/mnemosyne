# ═══════════════════════════════════════════════════════════════
#  Mnemosyne RAG Server — Environment Configuration
#  Copy this to .env and fill in all values before deploying:
#    cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# ── Authentication (REQUIRED) ────────────────────────────────────
# Generate RAG_API_KEY with: openssl rand -hex 32
RAG_API_KEY=3142174e8a4e4621950640da963358afb8c9c8f0e1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p7q8r9s0t1u2v3w4x5y6z7
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456789
SESSION_TTL_HOURS=8

# ── OpenRouter — Cloud LLM (REQUIRED) ────────────────────────────
# Sign up free at https://openrouter.ai  → Keys → Create Key
# Free models need no credits. Add credits only for paid models.
OPENROUTER_API_KEY=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

# Free model options (pick one):
#   stepfun/step-3.5-flash:free               ← current (fast, multilingual)
#   microsoft/phi-3-mini-128k-instruct:free   ← 128k context
#   meta-llama/llama-3.1-8b-instruct:free     ← most capable free
#   mistralai/mistral-7b-instruct:free        ← good balance
#   google/gemma-2-9b-it:free                 ← Google, strong reasoning
#   qwen/qwen-2-7b-instruct:free              ← multilingual
OPENROUTER_MODEL=stepfun/step-3.5-flash:free

# Optional: shown in OpenRouter dashboard for usage tracking
APP_URL=http://localhost:3000
APP_TITLE=Mnemosyne RAG

# ── Ollama — Embeddings only (runs in Docker) ─────────────────────
# Only nomic-embed-text is used — no LLM model needed in Ollama
OLLAMA_HOST=http://ollama:11434
EMBED_MODEL=nomic-embed-text

# ── ChromaDB ──────────────────────────────────────────────────────
CHROMA_URL=http://chromadb:8000
CHROMA_COLLECTION=mnemosyne_knowledge

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
CACHE_TTL=3600

# ── RAG Tuning ────────────────────────────────────────────────────
TOP_K=5
MIN_RELEVANCE_SCORE=0.15
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_MAX=60
QUERY_RATE_LIMIT=20
QUERY_CONCURRENCY=3

# ── Upload ────────────────────────────────────────────────────────
MAX_FILE_SIZE=50
UPLOAD_DIR=/tmp/rag-uploads
